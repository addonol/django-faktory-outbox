# ⚠️  WARNING: FOR DEMONSTRATION AND DEVELOPMENT PURPOSES ONLY ⚠️
#
# These are EXAMPLE values. NEVER use these credentials in production.
# In a real environment, use a Secrets Manager (Vault, AWS Secrets Manager)
# and deploy via secure automation (e.g., Ansible with encrypted variables).
###############################################################################

# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE - DJANGO FAKTORY OUTBOX
# ==============================================================================
# WARNING: This configuration file is for DEMONSTRATION and DEVELOPMENT only.
# Rename this file to '.env' and populate the actual secrets locally.
# Do not commit the final '.env' file to your Git repository history.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Database Credentials & Parameter Blocks (Shared Across Profiles)
# ------------------------------------------------------------------------------
# These fallback configurations are used to bootstrap database containers.
DB_HOST=localhost
DB_NAME=outbox_db
DB_USER=user
DB_PASSWORD=demo_password_123

# ------------------------------------------------------------------------------
# Active Database Connection URL Selection String (Pick One)
# ------------------------------------------------------------------------------
# Unleash specific backend testing profiles by uncommenting the desired URL.
# Ensure the chosen URL matches the active '--profile' flag in Docker Compose.

# Option A: PostgreSQL Active Topology Target Configuration
DATABASE_URL=postgres://user:demo_password_123@database_postgres:5432/outbox_db

# Option B: MariaDB Active Topology Target Configuration
# DATABASE_URL=mariadb://user:demo_password_123@database_mariadb:3306/outbox_db

# Option C: MySQL Active Topology Target Configuration
# DATABASE_URL=mysql://user:demo_password_123@database_mysql:3306/outbox_db

# ------------------------------------------------------------------------------
# Faktory Broker Interface Configuration
# ------------------------------------------------------------------------------
# FAKTORY_HOST should remain 'localhost' for local host evaluations.
FAKTORY_HOST=localhost
FAKTORY_PASSWORD=change_this_to_a_secure_development_password

# ------------------------------------------------------------------------------
# Standalone Relay Engine Adjustments
# ------------------------------------------------------------------------------
# Controls processing speeds, delivery sizes, and debug output levels.
RELAY_DEBUG=true
RELAY_BATCH_SIZE=1000
