###############################################################################
# ⚠️  WARNING: FOR DEMONSTRATION AND DEVELOPMENT PURPOSES ONLY ⚠️
#
# These are EXAMPLE values. NEVER use these credentials in production.
# In a real environment, use a Secrets Manager (Vault, AWS Secrets Manager)
# and deploy via secure automation (e.g., Ansible with encrypted variables).
###############################################################################

# --- Database Configuration ---
# Used by Postgres container and Django/Relay connections
DB_USER=user
DB_PASSWORD=mysecretpassword
DB_NAME=outbox_db
# Use 'localhost' for host-side development, or 'pg_db' for container networking
DB_HOST=localhost

# --- Faktory Configuration ---
# Used by Faktory container and the Relay engine
FAKTORY_PASSWORD=anothersecret123
# Use 'localhost' for host-side development, or 'faktory' for container networking
FAKTORY_HOST=localhost

# --- Application Tuning ---
# Set to 'True' to see heartbeat scans and detailed connection logs
RELAY_DEBUG=True

# Number of jobs processed in a single database transaction
RELAY_BATCH_SIZE=1000

# Default job count for the 'make stress' command
STRESS_COUNT=20000
